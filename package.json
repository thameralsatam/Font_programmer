    "motion": "^12.23.24",
    "opentype.js": "^1.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svg-pathdata": "^8.0.0",
    "svgpath": "^2.6.0",
    "vite": "^6.2.0"
  },
